# Copy to terraform.tfvars (gitignored) and apply:
#   terraform init && terraform apply
#
# github_repository must be owner/repo only — e.g. nkurunziza1/alex-ai_researcher

aws_region                     = "us-east-1"
github_repository              = "YOUR_GITHUB_USER/YOUR_REPO_NAME"
create_github_oidc_provider    = false
