{
  "browser": {
    "launchOptions": {
      "args": [
        "--disable-dev-shm-usage",
        "--no-sandbox",
        "--disable-setuid-sandbox",
        "--disable-gpu",
        "--disable-software-rasterizer",
        "--window-size=1280,900"
      ]
    }
  },
  "timeouts": {
    "navigation": 90000,
    "action": 20000
  }
}
